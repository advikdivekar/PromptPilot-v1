{
    "manifest_version": 2,
    "name": "PromptPilot",
    "version": "0.0.1",
    "description": "Receives engineered prompts from PromptPilot and pastes them into AI tools",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "alarms",
        "tabs",
        "http://localhost:54321/*",
        "ws://localhost:54321/*"
    ],
    "background": {
        "scripts": [
            "background.js"
        ],
        "persistent": false
    },
    "content_scripts": [
        {
            "matches": [
                "https://claude.ai/*",
                "https://chatgpt.com/*",
                "https://gemini.google.com/*",
                "https://www.perplexity.ai/*",
                "https://chat.openai.com/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ],
    "browser_action": {
        "default_popup": "popup.html",
        "default_title": "PromptPilot"
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "promptpilot@promptpilot.dev",
            "strict_min_version": "109.0"
        }
    }
}